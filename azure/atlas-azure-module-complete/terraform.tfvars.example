# Regions with Private Link subnet IDs
regions = [
  {
    name      = "US_EAST_2"
    subnet_id = "<YOUR_SUBNET_ID>"
  },
  {
    name      = "US_WEST_2"
    subnet_id = "<YOUR_SUBNET_ID>"
  }
]
