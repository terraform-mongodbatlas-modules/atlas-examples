# Update the placeholder values below with your values

# Atlas
atlas_org_id = "<YOUR_ATLAS_ORG_ID>"
project_name = "<NAME_FOR_ATLAS_PROJECT>"
cluster_name = "<NAME_FOR_ATLAS_CLUSTER>"

# Azure
azure_resource_group_name = "<YOUR_RESOURCE_GROUP>"
