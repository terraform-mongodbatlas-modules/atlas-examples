#cloud-config
package_update: true
package_upgrade: false

packages:
  - curl
  - wget
  - netcat-openbsd
  - dnsutils
  - jq
  - ca-certificates
  - gnupg

write_files:
  # OIDC validation script
  - path: /home/${admin_username}/validate-oidc
    owner: ${admin_username}:${admin_username}
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      # Validate Atlas connectivity using Azure Managed Identity (OIDC)
      # Usage: ./validate-oidc <connection-string> [ping|crud]
      
      set -euo pipefail
      
      URI="$${1:-}"
      TEST="$${2:-ping}"
      
      if [ -z "$URI" ]; then
        echo "Usage: ./validate-oidc <connection-string> [ping|crud]"
        echo "Example: ./validate-oidc 'mongodb+srv://cluster.mongodb.net'"
        exit 1
      fi
      
      echo "=== OIDC Validation ==="
      echo "Fetching Azure managed identity token..."
      
      TOKEN=$(curl -s -H "Metadata:true" \
        "http://169.254.169.254/metadata/identity/oauth2/token?api-version=2018-02-01&resource=api://AzureADTokenExchange" \
        | jq -r '.access_token')
      
      if [ "$TOKEN" = "null" ] || [ -z "$TOKEN" ]; then
        echo "ERROR: Failed to get managed identity token"
        exit 1
      fi
      
      echo "Token acquired. Connecting to MongoDB..."
      
      if [ "$TEST" = "crud" ]; then
        mongosh "$URI" --authenticationMechanism MONGODB-OIDC --oidcAccessToken "$TOKEN" --quiet --eval "
          db = db.getSiblingDB('validation_test');
          db.test.insertOne({_id:'oidc_test', ts: new Date()});
          print('Insert: OK');
          var doc = db.test.findOne({_id:'oidc_test'});
          print('Read: ' + JSON.stringify(doc));
          db.test.deleteOne({_id:'oidc_test'});
          print('Delete: OK');
          print('OIDC CRUD validation complete!');
        "
      else
        mongosh "$URI" --authenticationMechanism MONGODB-OIDC --oidcAccessToken "$TOKEN" --quiet --eval "
          var result = db.adminCommand('ping');
          print('Ping: ' + JSON.stringify(result));
          print('OIDC connection successful!');
        "
      fi

  # Connection test script (for SCRAM auth)
  - path: /home/${admin_username}/validate-connection
    owner: ${admin_username}:${admin_username}
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      # Validate Atlas connectivity over PrivateLink
      # Verifies DNS resolves to private IP and connection succeeds
      # Usage: ./validate-connection <connection-string-with-credentials>
      
      set -euo pipefail
      
      CONNECTION_STRING="$${1:-}"
      
      if [ -z "$CONNECTION_STRING" ]; then
        echo "Usage: ./validate-connection <connection-string>"
        echo "Example: ./validate-connection 'mongodb+srv://user:pass@cluster.mongodb.net'"
        exit 1
      fi
      
      echo "=== Atlas PrivateLink Connectivity Test ==="
      
      # Extract hostname from connection string
      HOST=$(echo "$CONNECTION_STRING" | sed -n 's|.*mongodb.*://[^@]*@\([^/]*\).*|\1|p')
      if [ -z "$HOST" ]; then
        HOST=$(echo "$CONNECTION_STRING" | sed -n 's|.*mongodb.*://\([^/]*\).*|\1|p')
      fi
      
      echo "1. Testing DNS resolution for: $HOST"
      if ! nslookup "$HOST" > /dev/null 2>&1; then
        echo "   DNS: FAILED"
        exit 1
      fi
      echo "   DNS: OK"
      
      # Get SRV records to find actual MongoDB hosts
      echo ""
      echo "2. Verifying private IP resolution..."
      SRV_HOSTS=$(dig +short SRV "_mongodb._tcp.$HOST" | awk '{print $4}' | sed 's/\.$//')
      
      if [ -z "$SRV_HOSTS" ]; then
        echo "   WARNING: No SRV records found, checking A record directly"
        SRV_HOSTS="$HOST"
      fi
      
      PRIVATE_VERIFIED=false
      for SRV_HOST in $SRV_HOSTS; do
        IP=$(dig +short "$SRV_HOST" | head -1)
        if [ -z "$IP" ]; then
          echo "   ERROR: Could not resolve $SRV_HOST"
          continue
        fi
        
        # Check if IP is in private ranges (10.x, 172.16-31.x, 192.168.x)
        if [[ $IP =~ ^10\. ]] || [[ $IP =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] || [[ $IP =~ ^192\.168\. ]]; then
          echo "   $SRV_HOST -> $IP (private)"
          PRIVATE_VERIFIED=true
        else
          echo "   ERROR: $SRV_HOST -> $IP (PUBLIC - not using PrivateLink!)"
          exit 1
        fi
      done
      
      if [ "$PRIVATE_VERIFIED" = false ]; then
        echo "   ERROR: Could not verify private IP resolution"
        exit 1
      fi
      echo "   Private network: VERIFIED"
      
      echo ""
      echo "3. Testing MongoDB connection..."
      if mongosh "$CONNECTION_STRING" --quiet --eval "db.adminCommand('ping')"; then
        echo ""
        echo "=== PrivateLink connectivity VERIFIED ==="
      else
        echo ""
        echo "Connection FAILED"
        exit 1
      fi

  # CRUD validation script (for SCRAM auth)
  - path: /home/${admin_username}/validate-crud
    owner: ${admin_username}:${admin_username}
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      # Validate CRUD operations over PrivateLink
      # Usage: ./validate-crud <connection-string-with-credentials>
      
      set -euo pipefail
      
      CONNECTION_STRING="$${1:-}"
      
      if [ -z "$CONNECTION_STRING" ]; then
        echo "Usage: ./validate-crud <connection-string>"
        echo "Example: ./validate-crud 'mongodb+srv://user:pass@cluster.mongodb.net'"
        exit 1
      fi
      
      echo "=== CRUD Validation over PrivateLink ==="
      
      mongosh "$CONNECTION_STRING" --quiet --eval "
        db = db.getSiblingDB('validation_test');
        
        print('1. Insert...');
        db.test.insertOne({_id:'crud_test', ts: new Date()});
        print('   Insert: OK');
        
        print('2. Read...');
        var doc = db.test.findOne({_id:'crud_test'});
        print('   Read: ' + JSON.stringify(doc));
        
        print('3. Update...');
        db.test.updateOne({_id:'crud_test'}, {\$set: {updated: true}});
        print('   Update: OK');
        
        print('4. Delete...');
        db.test.deleteOne({_id:'crud_test'});
        print('   Delete: OK');
        
        print('');
        print('CRUD validation complete!');
      "

  # Network isolation verification script
  - path: /home/${admin_username}/validate-privatelink
    owner: ${admin_username}:${admin_username}
    permissions: "0755"
    defer: true
    content: |
      #!/bin/bash
      # Comprehensive PrivateLink validation
      # Verifies: private DNS, private IP resolution, and optionally that public path fails
      # Usage: ./validate-privatelink <private-connection-string> [public-connection-string]
      
      set -euo pipefail
      
      PRIVATE_URI="$${1:-}"
      PUBLIC_URI="$${2:-}"
      
      if [ -z "$PRIVATE_URI" ]; then
        echo "Usage: ./validate-privatelink <private-connection-string> [public-connection-string]"
        echo ""
        echo "Examples:"
        echo "  ./validate-privatelink 'mongodb+srv://user:pass@cluster-pl-0.xxx.mongodb.net'"
        echo "  ./validate-privatelink 'mongodb+srv://user:pass@cluster-pl-0.xxx.mongodb.net' 'mongodb+srv://user:pass@cluster.xxx.mongodb.net'"
        exit 1
      fi
      
      echo "========================================"
      echo "  Atlas PrivateLink Validation Suite"
      echo "========================================"
      echo ""
      
      # Extract hostname from private connection string
      PRIVATE_HOST=$(echo "$PRIVATE_URI" | sed -n 's|.*mongodb.*://[^@]*@\([^/]*\).*|\1|p')
      if [ -z "$PRIVATE_HOST" ]; then
        PRIVATE_HOST=$(echo "$PRIVATE_URI" | sed -n 's|.*mongodb.*://\([^/]*\).*|\1|p')
      fi
      
      echo "=== Test 1: Private DNS Resolution ==="
      echo "Host: $PRIVATE_HOST"
      echo ""
      
      # Get SRV records
      SRV_HOSTS=$(dig +short SRV "_mongodb._tcp.$PRIVATE_HOST" | awk '{print $4}' | sed 's/\.$//')
      
      if [ -z "$SRV_HOSTS" ]; then
        echo "WARNING: No SRV records, checking A record"
        SRV_HOSTS="$PRIVATE_HOST"
      fi
      
      ALL_PRIVATE=true
      for SRV_HOST in $SRV_HOSTS; do
        IP=$(dig +short "$SRV_HOST" | head -1)
        if [ -z "$IP" ]; then
          echo "  ERROR: Could not resolve $SRV_HOST"
          ALL_PRIVATE=false
          continue
        fi
        
        if [[ $IP =~ ^10\. ]] || [[ $IP =~ ^172\.(1[6-9]|2[0-9]|3[0-1])\. ]] || [[ $IP =~ ^192\.168\. ]]; then
          echo "  $SRV_HOST"
          echo "    -> $IP (PRIVATE)"
        else
          echo "  $SRV_HOST"
          echo "    -> $IP (PUBLIC - FAIL!)"
          ALL_PRIVATE=false
        fi
      done
      
      echo ""
      if [ "$ALL_PRIVATE" = true ]; then
        echo "Result: PASS - All IPs are private"
      else
        echo "Result: FAIL - Public IPs detected"
        exit 1
      fi
      
      echo ""
      echo "=== Test 2: Private Endpoint Connection ==="
      if mongosh "$PRIVATE_URI" --quiet --eval "db.adminCommand('ping')" > /dev/null 2>&1; then
        echo "Result: PASS - Connection successful"
      else
        echo "Result: FAIL - Connection failed"
        exit 1
      fi
      
      # Optional: Test that public path fails
      if [ -n "$PUBLIC_URI" ]; then
        echo ""
        echo "=== Test 3: Public Path Blocked ==="
        PUBLIC_HOST=$(echo "$PUBLIC_URI" | sed -n 's|.*mongodb.*://[^@]*@\([^/]*\).*|\1|p')
        if [ -z "$PUBLIC_HOST" ]; then
          PUBLIC_HOST=$(echo "$PUBLIC_URI" | sed -n 's|.*mongodb.*://\([^/]*\).*|\1|p')
        fi
        echo "Testing: $PUBLIC_HOST"
        echo ""
        
        # Test with 5 second timeout
        if timeout 5 mongosh "$PUBLIC_URI" --quiet --eval "db.adminCommand('ping')" > /dev/null 2>&1; then
          echo "Result: FAIL - Public connection succeeded (network not isolated!)"
          exit 1
        else
          echo "Result: PASS - Public connection blocked (as expected)"
        fi
      fi
      
      echo ""
      echo "========================================"
      echo "  PrivateLink Validation: ALL PASSED"
      echo "========================================"

runcmd:
  - echo "Starting validation VM setup at $(date)" >> /var/log/cloud-init-validation.log

  # Install mongosh via direct download (more reliable than repo)
  - echo "Installing mongosh..." >> /var/log/cloud-init-validation.log
  - curl -fsSL https://downloads.mongodb.com/compass/mongosh-2.3.7-linux-x64.tgz -o /tmp/mongosh.tgz
  - tar -xzf /tmp/mongosh.tgz -C /tmp
  - cp /tmp/mongosh-*/bin/mongosh /usr/local/bin/
  - chmod +x /usr/local/bin/mongosh
  - ln -sf /usr/local/bin/mongosh /usr/bin/mongosh
  - rm -rf /tmp/mongosh*
  - mongosh --version >> /var/log/cloud-init-validation.log 2>&1

  - echo "Validation VM setup completed at $(date)" >> /var/log/cloud-init-validation.log

final_message: |
  Atlas Validation VM is ready!
  
  Available commands:
    ./validate-privatelink  - Comprehensive PrivateLink validation (recommended)
    ./validate-connection   - Test connectivity with private IP verification
    ./validate-crud         - Test CRUD operations
    ./validate-oidc         - Test OIDC authentication (requires Atlas OIDC setup)
  
  Quick start:
    ./validate-privatelink 'mongodb+srv://user:pass@cluster-pl-0.xxx.mongodb.net'
