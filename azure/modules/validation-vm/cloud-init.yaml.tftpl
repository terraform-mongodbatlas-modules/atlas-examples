#cloud-config
# ---------------------------------------------------------------------------
# Atlas Validation VM Cloud-Init Configuration
# ---------------------------------------------------------------------------
# Installs mongosh, Atlas CLI, and validation script for testing PrivateLink.
# Connection string is pre-configured - just run: ./validate-atlas
#
# For backup validation (optional):
#   export MONGODB_ATLAS_PUBLIC_API_KEY="key" MONGODB_ATLAS_PRIVATE_API_KEY="secret"
# ---------------------------------------------------------------------------

package_update: true
package_upgrade: false

packages:
  - curl
  - wget
  - netcat-openbsd
  - dnsutils
  - jq
  - ca-certificates
  - gnupg

write_files:
  # Connection string config file (pre-configured by Terraform)
  # defer: true ensures file is written after user creation
  - path: /home/${admin_username}/.atlas-connection
    owner: ${admin_username}:${admin_username}
    permissions: "0600"
    defer: true
    content: |
      ${connection_string}

  # Atlas project/cluster config for backup validation
  - path: /home/${admin_username}/.atlas-config
    owner: ${admin_username}:${admin_username}
    permissions: "0600"
    defer: true
    content: |
      ATLAS_PROJECT_ID="${atlas_project_id}"
      ATLAS_CLUSTER_NAME="${atlas_cluster_name}"

  # Validation script (content loaded from scripts/validate-atlas.sh)
  - path: /home/${admin_username}/validate-atlas
    owner: ${admin_username}:${admin_username}
    permissions: "0755"
    defer: true
    content: |
      ${indent(6, validate_script)}

runcmd:
  # Log file for debugging cloud-init
  - echo "=== Atlas Validation VM Setup ===" >> /var/log/cloud-init-validation.log
  - echo "Started at $(date)" >> /var/log/cloud-init-validation.log
  - echo "" >> /var/log/cloud-init-validation.log

  # ---------------------------------------------------------------------------
  # Install mongosh via MongoDB official apt repository (Ubuntu 22.04 Jammy)
  # ---------------------------------------------------------------------------
  - echo "Installing mongosh from MongoDB apt repository..." >> /var/log/cloud-init-validation.log
  
  # Import MongoDB public GPG key
  - curl -fsSL https://www.mongodb.org/static/pgp/server-7.0.asc | gpg --dearmor -o /usr/share/keyrings/mongodb-server-7.0.gpg 2>> /var/log/cloud-init-validation.log
  
  # Add MongoDB repository for Ubuntu 22.04 (Jammy)
  - echo "deb [ arch=amd64,arm64 signed-by=/usr/share/keyrings/mongodb-server-7.0.gpg ] https://repo.mongodb.org/apt/ubuntu jammy/mongodb-org/7.0 multiverse" > /etc/apt/sources.list.d/mongodb-org-7.0.list
  
  # Update package list and install mongosh
  - apt-get update >> /var/log/cloud-init-validation.log 2>&1
  - apt-get install -y mongodb-mongosh >> /var/log/cloud-init-validation.log 2>&1
  
  # Verify mongosh installation
  - echo "mongosh version:" >> /var/log/cloud-init-validation.log
  - mongosh --version >> /var/log/cloud-init-validation.log 2>&1 || echo "mongosh installation may have failed" >> /var/log/cloud-init-validation.log

  # ---------------------------------------------------------------------------
  # Install Atlas CLI for backup validation
  # ---------------------------------------------------------------------------
  - echo "" >> /var/log/cloud-init-validation.log
  - echo "Installing Atlas CLI..." >> /var/log/cloud-init-validation.log
  
  # Download and install Atlas CLI
  - curl -fsSL https://fastdl.mongodb.org/mongocli/mongodb-atlas-cli_1.14.0_linux_x86_64.deb -o /tmp/mongodb-atlas-cli.deb >> /var/log/cloud-init-validation.log 2>&1
  - dpkg -i /tmp/mongodb-atlas-cli.deb >> /var/log/cloud-init-validation.log 2>&1 || apt-get install -f -y >> /var/log/cloud-init-validation.log 2>&1
  - rm -f /tmp/mongodb-atlas-cli.deb
  
  # Verify Atlas CLI installation
  - echo "Atlas CLI version:" >> /var/log/cloud-init-validation.log
  - atlas --version >> /var/log/cloud-init-validation.log 2>&1 || echo "Atlas CLI installation may have failed" >> /var/log/cloud-init-validation.log

  # Set ownership of files
  - chown ${admin_username}:${admin_username} /home/${admin_username}/validate-atlas
  - chown ${admin_username}:${admin_username} /home/${admin_username}/.atlas-connection
  - chown ${admin_username}:${admin_username} /home/${admin_username}/.atlas-config

  - echo "" >> /var/log/cloud-init-validation.log
  - echo "Completed at $(date)" >> /var/log/cloud-init-validation.log
  - echo "=== Setup Complete ===" >> /var/log/cloud-init-validation.log

final_message: |
  ===========================================
  Atlas Validation VM is ready!
  ===========================================
  
  Run: ./validate-atlas
  
  For backup validation (optional):
    export MONGODB_ATLAS_PUBLIC_API_KEY="key" MONGODB_ATLAS_PRIVATE_API_KEY="secret"
    ./validate-atlas
  
  Options:
    --strict  Exit on first failure (for CI/CD)
    --help    Show all options
  
  What it validates:
    1. DNS Resolution - All targets resolve to private IPs
    2. MongoDB Connection - mongosh can connect
    3. CRUD Operations - Insert/Read/Update/Delete works
    4. Backup Validation - Lists recent snapshots (requires API keys)
    5. Cluster Info - Displays version and topology
  
  For backup validation, set Atlas credentials (API keys or Service Account):
    export MONGODB_ATLAS_PUBLIC_API_KEY="key"
    export MONGODB_ATLAS_PRIVATE_API_KEY="secret"
    ./validate-atlas
  
  Check /var/log/cloud-init-validation.log for setup details.
